# CiteGuard configuration — copy to `.env` and fill in. NEVER commit real secrets.
# CiteGuard needs NO secrets to run; both values below are optional niceties.

# Contact email used for the "polite pools" of Crossref / OpenAlex / Unpaywall
# and the NCBI E-utilities tool/email parameters. Providing a real address gives
# you higher, more reliable rate limits and enables Unpaywall open-access links.
# Without it, CiteGuard still verifies citations (just without OA links).
CITEGUARD_CONTACT_EMAIL=you@wustl.edu

# OPTIONAL. An NCBI API key raises the PubMed E-utilities rate limit from 3 to
# 10 requests/second. Not required. In the deployed AgenticNetwork this is
# supplied per-user as the credential type `ncbi_api_key` and arrives via
# context["credentials"]; locally you can set it here instead.
# NCBI_API_KEY=your-ncbi-api-key
